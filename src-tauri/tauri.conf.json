{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CloudDash AWS",
  "version": "1.0.2",
  "identifier": "dev.clouddash.aws",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "CloudDash for AWS",
        "width": 1366,
        "height": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE2OUZGM0VENzNCNERFN0EKUldSNjNyUno3Zk9mcGhTMFppU2NaaVRpL09UeDd3d1dvZmwxSm9VZVNTZHFVcnlkcVYwRzZTOC8K",
      "endpoints": [
        "https://clouddash.dev/updates/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}