{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "http:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        {
          "url": "https://*.amazonaws.com/*"
        },
        {
          "url": "https://*.aws.amazon.com/*"
        }
      ]
    }
  ]
}