{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "file://*"
        },
        {
          "url": "https://*"
        }
      ]
    },
    "http:default",
    "dialog:default",
    "fs:default",
    "scoped-storage:allow-pick-folder",
    "scoped-storage:allow-write-file",
    "scoped-storage:allow-exists",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        {
          "url": "https://*.amazonaws.com/*"
        },
        {
          "url": "https://*.aws.amazon.com/*"
        },
        {
          "url": "https://clouddash.dev/*"
        },
        {
          "url": "https://*.polar.sh/*"
        }
      ]
    }
  ]
}